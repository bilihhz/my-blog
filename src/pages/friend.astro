---
import Markdown from "@components/misc/Markdown.astro";
import Giscus from "../components/misc/giscus.astro";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";

// 将所有链接分类存放在一个对象里
const sections = [
	{
		title: "其他网站",
		content: [
			{
				name: "指令",
				desc: "指令生成器",
				url: "https://zl.hhz114514.qzz.io",
				avatar: "https://zl.hhz114514.qzz.io/instruction.png",
			},

			{
				name: "本站统计",
				desc: "Umami",
				url: "https://cloud.umami.is/share/zwNENJkXsBNXmIuP",
				avatar: "/favicon/web.ico",
			},

			{
				name: "指令统计",
				desc: "Umami",
				url: "https://cloud.umami.is/share/jXxNnr88jOOVmHGl/",
				avatar: "/favicon/web.ico",
			},

			{
				name: "监控1",
				desc: "uptimeflare",
				url: "https://uptime.hhz114514.qzz.io/",
				avatar: "https://uptime.hhz114514.qzz.io/favicon.png",
			},

			{
				name: "监控2",
				desc: "uptimerobot",
				url: "https://stats.uptimerobot.com/Vvl3i7j1N2",
				avatar: "https://stats.uptimerobot.com/assets/favicon.ico",
			},
		],
	},
	{
		title: "友情链接",
		content: [
			{
				name: "Candy Lazy",
				desc: "Lazy 的 Candy",
				url: "https://www.candywind.com",
				avatar: "https://www.candywind.com/upload/sk.png",
			},
		],
	},
];

const title = i18n(I18nKey.friend); 
// 下面有神秘单行html
---

<MainGridLayout title={title} description={title}>
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full">
            
            <Markdown class="mb-8"> 
                <h1 class="text-3xl font-bold mb-4">{title}</h1>
                <p class="text-black/70 dark:text-white/70">加友链可以通过<code>github提交pr</code>或<code>评论区</code>或<code>hello@hhz114514.qzz.io</code>找我<br>格式为<code>名称</code>、<code>描述</code>、<code>链接</code>、<code>图标</code></br>本站信息：</br><ul><li>名称: <code>hhz-blog</code></li><li>描述: <code>hhz的个人blog</code></li><li>链接: <code>https://hhz114514.qzz.io</code></li><li>图标: <code>https://hhz114514.qzz.io/favicon/web.ico</code></li></ul></p>
            </Markdown>

            {sections.map((section, index) => (
                <>
                    <div class="mb-6 flex items-center gap-2 text-black/50 dark:text-white/50 text-sm font-bold uppercase tracking-wider">
                        <div class="w-1 h-4 bg-[var(--primary)] rounded-full"></div>
                        {section.title}
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        {section.content.map((link) => (
                            <a href={link.url} target="_blank" rel="noopener noreferrer" 
                               class="group flex items-center p-4 rounded-xl bg-[var(--page-bg)] border border-black/10 dark:border-white/10 hover:bg-[var(--primary)] transition-all duration-300 shadow-sm">
                                <div class="shrink-0">
                                    <img src={link.avatar} alt={link.name} class="w-12 h-12 rounded-lg object-cover border border-black/0 dark:border-white/0" onerror="this.src='/favicon/web.ico'"/>
                                </div>
                                <div class="ml-4 overflow-hidden">
                                    <div class="font-bold text-lg truncate transition-all duration-300 text-black/80 dark:text-white/90 group-hover:text-white">{link.name}</div>
                                    <div class="text-sm truncate transition-all duration-300 text-black/70 dark:text-white/70 group-hover:text-white/80">{link.desc}</div>
                                </div>
                            </a>
                        ))}
                    </div>

                    {index < sections.length - 1 && (
                        <div class="border-t border-black/[0.06] dark:border-white/[0.06] my-10"></div>
                    )}
                </>
            ))}
            <Giscus
                repo="bilihhz/blog-giscus"
                repoId="R_kgDORLVzaw"
                category="Announcements"
                categoryId="DIC_kwDORLVza84C2CuY"
            />
        </div>
    </div>
    
</MainGridLayout>